generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Source {
  id                   Int       @id @default(autoincrement())
  name                 String    @db.VarChar(255)
  sourceType           SourceType @default(RSS) @map("source_type")
  baseUrl              String    @db.VarChar(2048) @map("base_url")
  rssUrl               String?   @unique @db.VarChar(2048) @map("rss_url")
  latestPageUrl        String?   @db.VarChar(2048) @map("latest_page_url")
  isActive             Boolean   @default(true) @map("is_active")
  fetchIntervalMinutes Int       @default(15) @map("fetch_interval_minutes")
  lastFetchedAt        DateTime? @map("last_fetched_at")
  latestArticlePublishedAt DateTime? @map("latest_article_published_at")
  lastSuccessAt        DateTime? @map("last_success_at")
  lastError            String?   @db.Text @map("last_error")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  articles             Article[]

  @@index([isActive])
  @@map("sources")
}

model Article {
  id                Int           @id @default(autoincrement())
  sourceId          Int           @map("source_id")
  title             String        @db.VarChar(1000)
  url               String        @unique @db.VarChar(2048)
  content           String?       @db.Text
  excerpt           String?       @db.Text
  imageUrl          String?       @db.VarChar(2048) @map("image_url")
  publishedAt       DateTime?     @map("published_at")
  contentHash       String        @db.VarChar(64) @map("content_hash")
  status            ArticleStatus @default(NEW)
  rewrittenTitleUz  String?       @db.VarChar(1000) @map("rewritten_title_uz")
  summaryUz         String?       @db.Text @map("summary_uz")
  category          String?       @db.VarChar(100) @map("category")
  aiModel           String?       @db.VarChar(100) @map("ai_model")
  aiRawResponse     String?       @db.Text @map("ai_raw_response")
  processedAt       DateTime?     @map("processed_at")
  ingestedViaLatestOnly Boolean   @default(false) @map("ingested_via_latest_only")
  retryCount        Int           @default(0) @map("retry_count")
  telegramMessageId String?       @db.VarChar(255) @map("telegram_message_id")
  publishError      String?       @db.Text @map("publish_error")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  source            Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([status])
  @@index([publishedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("articles")
}

enum ArticleStatus {
  NEW
  PROCESSING
  APPROVED
  PUBLISHED
  FAILED
}

enum SourceType {
  RSS
  HTML
}
