# Database
DATABASE_URL="postgresql://news_intelligence:news_intelligence_password@localhost:5432/news_intelligence?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Application
NODE_ENV="development"
PORT=3000
API_PREFIX="api"

# OpenAI API (for future use)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
AI_MAX_INPUT_CHARS=2500
AI_MAX_PARAGRAPHS=4
AI_MAX_OUTPUT_TOKENS=500
KUN_UZ_RSS_URL="https://kun.uz/news/rss"
KUN_UZ_LATEST_PAGE_URL="https://kun.uz/news"
QALAMPIR_SOURCE_TYPE="RSS"
QALAMPIR_RSS_URL="https://qalampir.uz/rss"
QALAMPIR_LATEST_PAGE_URL="https://qalampir.uz/uz"
ZAMON_LATEST_PAGE_URL="https://zamon.uz/uz/news"

# Telegram Bot (for future use)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""
AUTO_PUBLISH_ENABLED=true
TELEGRAM_PUBLISHING_ENABLED=true
AUTO_PUBLISH_MAX_PER_RUN=1
TELEGRAM_DAILY_PUBLISH_LIMIT=10
AUTO_PUBLISH_FRESH_HOURS=24
AI_DAILY_PROCESS_LIMIT=10
AI_PROCESS_MAX_PER_RUN=1
AI_PROCESS_FRESH_HOURS=24

# Admin User
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"
ADMIN_USERNAME="admin"

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Queue Settings
QUEUE_CONCURRENT_JOBS=3
QUEUE_JOB_TIMEOUT=60000

# Logging
LOG_LEVEL="debug"
