# Database
DATABASE_URL="postgresql://news_intelligence:news_intelligence_password@localhost:5432/news_intelligence?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Application
NODE_ENV="development"
PORT=3000
API_PREFIX="api"

# OpenAI API (for future use)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"

# Telegram Bot (for future use)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""

# Admin User
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"
ADMIN_USERNAME="admin"

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Queue Settings
QUEUE_CONCURRENT_JOBS=3
QUEUE_JOB_TIMEOUT=60000

# Logging
LOG_LEVEL="debug"
