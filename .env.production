# =====================================================
# AI News Intelligence Platform - Production Environment
# =====================================================
# IMPORTANT: Copy this file to .env and update values
# DO NOT commit .env to version control
# DO NOT use default passwords in production
# =====================================================

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Use strong password with at least 16 characters, mixed case, numbers, symbols
DATABASE_URL="postgresql://news_intelligence:CHANGE_THIS_STRONG_PASSWORD_NOW@postgres:5432/news_intelligence?schema=public"

# =====================================================
# REDIS CONFIGURATION
# =====================================================
# Format: redis://HOST:PORT
# For production with password: redis://:PASSWORD@HOST:PORT
REDIS_URL="redis://redis:6379"

# =====================================================
# APPLICATION CONFIGURATION
# =====================================================
NODE_ENV="production"
PORT="3000"
API_PREFIX="api"

# =====================================================
# OPENAI API CONFIGURATION
# =====================================================
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-CHANGE_THIS_TO_YOUR_OPENAI_API_KEY"

# OpenAI Model Configuration
OPENAI_MODEL_SUMMARY="gpt-4o-mini"
OPENAI_MODEL_CLASSIFICATION="gpt-4o-mini"
OPENAI_MODEL_SENTIMENT="gpt-4o-mini"

# OpenAI Rate Limits (requests per minute)
OPENAI_RATE_LIMIT="60"

# =====================================================
# TELEGRAM BOT CONFIGURATION
# =====================================================
# Get bot token from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN="CHANGE_THIS_TO_YOUR_TELEGRAM_BOT_TOKEN"

# Telegram Channel ID (format: @channel_name or -100xxxxxxxxxx)
TELEGRAM_CHANNEL_ID="@YOUR_TELEGRAM_CHANNEL"

# Telegram Publishing Configuration
TELEGRAM_RATE_LIMIT_MESSAGES_PER_SECOND="30"
TELEGRAM_RATE_LIMIT_MESSAGES_PER_MINUTE_PER_CHAT="20"
TELEGRAM_RATE_LIMIT_MESSAGES_PER_HOUR_PER_CHAT="200"

# =====================================================
# ADMIN USER CONFIGURATION
# =====================================================
# Initial admin user credentials
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_THIS_STRONG_ADMIN_PASSWORD"

# =====================================================
# RATE LIMITING CONFIGURATION
# =====================================================
# API Rate Limiting (requests per window)
RATE_LIMIT_TTL="60"
RATE_LIMIT_LIMIT="100"

# =====================================================
# QUEUE CONFIGURATION
# =====================================================
# BullMQ Queue Configuration
QUEUE_CONCURRENT_JOBS="3"
QUEUE_JOB_TIMEOUT="60000"

# Queue Settings
QUEUE_RETRY_ATTEMPTS="3"
QUEUE_RETRY_DELAY="5000"

# =====================================================
# RSS FETCHING CONFIGURATION
# =====================================================
# RSS Fetch Schedule (cron expression)
RSS_FETCH_SCHEDULE="*/15 * * * *"

# RSS Request Settings
RSS_TIMEOUT="30000"
RSS_USER_AGENT="Mozilla/5.0 (compatible; NewsIntelligence/1.0)"

# RSS Error Handling
RSS_MAX_RETRIES="3"
RSS_RETRY_DELAY="5000"

# RSS Circuit Breaker
RSS_CIRCUIT_BREAKER_THRESHOLD="5"
RSS_CIRCUIT_BREAKER_TIMEOUT="300000"

# =====================================================
# CONTENT EXTRACTION CONFIGURATION
# =====================================================
# Scraping Configuration
SCRAPING_ENABLED="true"
SCRAPING_TIMEOUT="30000"
SCRAPING_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"

# Content Validation
MIN_TITLE_LENGTH="10"
MIN_CONTENT_LENGTH="50"
MAX_CONTENT_LENGTH="50000"

# =====================================================
# DUPLICATE DETECTION CONFIGURATION
# =====================================================
# Similarity Thresholds (0.0 - 1.0)
DUPLICATE_TITLE_SIMILARITY_THRESHOLD="0.9"
DUPLICATE_CONTENT_SIMILARITY_THRESHOLD="0.8"

# AI Semantic Check
DUPLICATE_AI_SEMANTIC_CHECK_ENABLED="true"
DUPLICATE_AI_SEMANTIC_CHECK_THRESHOLD="0.85"

# =====================================================
# AI PROCESSING CONFIGURATION
# =====================================================
# AI Cost Optimization
AI_CACHE_ENABLED="true"
AI_CACHE_TTL="3600000"

# AI Processing Limits
AI_MAX_CONTENT_LENGTH="2000"
AI_TRUNCATE_ENABLED="true"

# Token Tracking
AI_TOKEN_TRACKING_ENABLED="true"
AI_DAILY_BUDGET_CENTS="1000"

# =====================================================
# TELEGRAM PUBLISHING CONFIGURATION
# =====================================================
# Message Formatting
TELEGRAM_PARSE_MODE="Markdown"
TELEGRAM_DISABLE_WEB_PAGE_PREVIEW="false"

# Message Limits
TELEGRAM_MAX_MESSAGE_LENGTH="4096"

# Publishing Schedule
TELEGRAM_PUBLISH_IMMEDIATE="true"
TELEGRAM_SCHEDULED_PUBLISHING_ENABLED="false"

# =====================================================
# LOGGING CONFIGURATION
# =====================================================
# Log Level: error, warn, info, http, verbose, debug, silly
LOG_LEVEL="info"

# Log Format
LOG_FORMAT="json"

# Log Rotation
LOG_MAX_FILES="14"
LOG_MAX_SIZE="10m"

# =====================================================
# MONITORING CONFIGURATION
# =====================================================
# Health Check Configuration
HEALTH_CHECK_ENABLED="true"
HEALTH_CHECK_INTERVAL="30000"

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED="true"

# Error Tracking
ERROR_TRACKING_ENABLED="true"

# =====================================================
# SECURITY CONFIGURATION
# =====================================================
# CORS Configuration
CORS_ENABLED="true"
CORS_ORIGIN="*"

# Session Configuration
SESSION_SECRET="CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_FOR_SESSIONS"

# JWT Configuration (if using JWT)
JWT_SECRET="CHANGE_THIS_TO_A_VERY_LONG_RANDOM_STRING_FOR_JWT"
JWT_EXPIRATION="7d"

# =====================================================
# BACKUP CONFIGURATION
# =====================================================
# Database Backup
BACKUP_ENABLED="true"
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="7"

# Backup Location
BACKUP_DIRECTORY="/opt/backups/news-intelligence"

# =====================================================
# DEVELOPMENT/DEBUGGING (DISABLE IN PRODUCTION)
# =====================================================
# Debug Mode
DEBUG="false"

# Swagger/API Documentation
SWAGGER_ENABLED="false"

# Prisma Studio (NEVER enable in production)
PRISMA_STUDIO_ENABLED="false"

# =====================================================
# FEATURE FLAGS
# =====================================================
# Phase 2 Features
RSS_PROCESSING_ENABLED="false"
CONTENT_EXTRACTION_ENABLED="false"
DUPLICATE_DETECTION_ENABLED="false"

# Phase 3 Features
AI_PROCESSING_ENABLED="false"
TELEGRAM_PUBLISHING_ENABLED="false"
ADMIN_DASHBOARD_ENABLED="false"

# Phase 4 Features
ADVANCED_ANALYTICS_ENABLED="false"
TRENDING_DETECTION_ENABLED="false"
MULTI_CHANNEL_SUPPORT_ENABLED="false"

# =====================================================
# IMPORTANT NOTES
# =====================================================
# 1. Replace all CHANGE_THIS_* values with actual values
# 2. Use strong, unique passwords (min 16 characters)
# 3. Never commit .env file to version control
# 4. Set proper file permissions: chmod 600 .env
# 5. Keep backup copies of .env in secure location
# 6. Rotate API keys and passwords regularly
# 7. Monitor API usage and costs
# 8. Set up alerts for critical failures
# 9. Test configuration changes in staging first
# 10. Document all configuration changes

# =====================================================
# SECURITY CHECKLIST
# =====================================================
# [ ] All passwords changed from defaults
# [ ] API keys are valid and have proper permissions
# [ ] DATABASE_URL uses strong password
# [ ] REDIS_URL uses strong password (if auth enabled)
# [ ] ADMIN_PASSWORD is strong and unique
# [ ] JWT_SECRET is long and random
# [ ] SESSION_SECRET is long and random
# [ ] Feature flags are set appropriately
# [ ] Debug features are disabled
# [ ] CORS is configured correctly
# [ ] Rate limiting is enabled
# [ ] Logging is set to appropriate level
# [ ] Backups are enabled and scheduled

# =====================================================
# AFTER DEPLOYMENT
# =====================================================
# 1. Verify all services are running
# 2. Test health endpoint: curl http://localhost:3000/health
# 3. Check logs for errors
# 4. Verify database connections
# 5. Test API endpoints
# 6. Monitor system resources
# 7. Set up monitoring alerts
# 8. Test backup procedures
# 9. Document any issues or changes
# 10. Schedule regular maintenance